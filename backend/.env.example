# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://loco:loco_secret@localhost:5432/loco_twin?sslmode=disable
POSTGRES_USER=loco
POSTGRES_PASSWORD=loco_secret
POSTGRES_DB=loco_twin
POSTGRES_PORT=5432

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=INFO
LOG_PRETTY=true
LOG_DIR=

# ── Swagger ───────────────────────────────────────────────────────────────────
SWAGGER_HOST=localhost:8080

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# ── Simulation ────────────────────────────────────────────────────────────────
LOCO_ID=00000000-0000-0000-0000-000000000001
TICK_INTERVAL=1s
METRICS_CONFIG=./metrics.yaml
MIGRATIONS_PATH=db/migrations

# ── Aggregator pipeline ───────────────────────────────────────────────────────
BUFFER_CAP=50
FLUSH_INTERVAL_MS=500

# ── Retention ─────────────────────────────────────────────────────────────────
TELEMETRY_RETENTION=72h
EMA_RECALC_INTERVAL=1h
